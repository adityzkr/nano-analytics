{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "server"],
      "port": 4000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "web"],
      "port": 5173
    },
    {
      "name": "demo-site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "demo-site"],
      "port": 8080
    },
    {
      "name": "api-id",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "server", "--prefix", "identified"],
      "port": 4100
    },
    {
      "name": "web-id",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace", "web", "--prefix", "identified"],
      "port": 5174
    }
  ]
}
